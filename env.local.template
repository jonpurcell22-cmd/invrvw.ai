# Project URL + either anon key or publishable key (Supabase → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Alternative: NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Admin features (Supabase → Project Settings → API Keys → service_role secret)
ADMIN_EMAIL=your_admin_email@example.com
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ANTHROPIC_API_KEY=your_anthropic_api_key
